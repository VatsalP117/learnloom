# Public hostname contract. These four values should not differ in production.
LEARNLOOM_ROOT_DOMAIN=learnloom.blog
LEARNLOOM_APP_ORIGIN=https://app.learnloom.blog
VITE_LEARNLOOM_ROOT_DOMAIN=learnloom.blog
LEARNLOOM_ENV=production
LOG_LEVEL=info

# Generate these with `openssl rand -hex 32` (Postgres may use 24 bytes).
POSTGRES_PASSWORD=replace-with-url-safe-random-hex
CSRF_SECRET=replace-with-at-least-32-random-characters
S3_BUCKET=learnloom-dossiers
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=replace-with-random-access-key
S3_SECRET_ACCESS_KEY=replace-with-at-least-32-random-characters
SEARXNG_SECRET=replace-with-at-least-32-random-characters

# Clerk production instance. The publishable values must match.
VITE_CLERK_PUBLISHABLE_KEY=pk_live_replace_me
CLERK_PUBLISHABLE_KEY=pk_live_replace_me
CLERK_SECRET_KEY=sk_live_replace_me
CLERK_JWT_KEY=replace-with-the-production-PEM-public-key
CLERK_WEBHOOK_SECRET=whsec_replace_me
CLERK_FRONTEND_ORIGIN=https://your-production-clerk-frontend-api

# Any OpenAI-compatible model provider.
MODEL_BASE_URL=https://api.deepseek.com
MODEL_API_KEY=replace-me
MODEL_NAME=deepseek-chat
MODEL_TIMEOUT=10m
MODEL_RETRIES=2
MODEL_MAX_TOKENS=8192

# Use a sender/domain verified in Resend.
RESEND_API_KEY=re_replace_me
RESEND_FROM=Learnloom <dossiers@learnloom.blog>
RESEND_SUBJECT_PREFIX=Learnloom

# Autonomous source discovery. Keep true when deploying the bundled SearXNG.
SOURCE_DISCOVERY_ENABLED=true
