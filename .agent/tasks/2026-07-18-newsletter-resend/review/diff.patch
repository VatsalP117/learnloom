+      delivery.issue.id,
+      receipt.externalId,
+      options.now ?? clock(),
+    );
+    onEvent({
+      type: "delivery-complete",
+      issueId: delivery.issue.id,
+      newsletterId: delivery.issue.newsletterId,
+      externalId: completed.externalId,
+    });
+    return completed;
