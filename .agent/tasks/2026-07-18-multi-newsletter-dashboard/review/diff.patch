+      provider: { kind: "demo" },
+      storage: { dataDirectory: "data", outputDirectory: "output" },
+    },
+    path.join(directory, "config.json"),
+  );
+  return {
+    config,
+    paths: resolveAppPaths(config, { env: {} }),
+    now: new Date("2026-07-18T06:00:00.000Z"),
+  };
+}
