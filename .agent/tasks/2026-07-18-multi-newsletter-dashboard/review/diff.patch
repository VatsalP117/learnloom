+  };
+  const first = await runDailyDossier({
+    config: fixture.config,
+    paths: fixture.paths,
+    demo: true,
+    now: fixture.now,
+    provider,
+    deliveries: [],
+  });
+  await rm(first.outputPath);
+  const second = await runDailyDossier({
+    config: fixture.config,
+    paths: fixture.paths,
+    demo: true,
+    now: fixture.now,
+    provider,
+    deliveries: [],
