+
+test("Daily Run regenerates when its recorded artifact is missing", async () => {
+  const fixture = await fixtureConfig();
+  let providerCalls = 0;
+  const demo = new DemoProvider();
+  const provider = {
+    async complete(input) {
+      providerCalls += 1;
+      return demo.complete(input);
