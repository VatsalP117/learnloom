+test("forced Daily Run creates a new delivery generation", async () => {
+  const fixture = await fixtureConfig();
+  const generations = [];
+  const delivery = {
+    id: "test-email",
+    async deliver({ generationId }) {
+      generations.push(generationId);
+      return { externalId: `sent-${generations.length}` };
