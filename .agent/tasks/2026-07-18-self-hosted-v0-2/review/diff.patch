+
+test("Daily Run skips an already delivered destination", async () => {
+  const fixture = await fixtureConfig();
+  let deliveryCalls = 0;
+  const delivery = {
+    id: "test-email",
+    async deliver() {
+      deliveryCalls += 1;
+      return { externalId: "sent-once" };
+    },
+  };
+  await runDailyDossier({
+    config: fixture.config,
+    paths: fixture.paths,
+    demo: true,
