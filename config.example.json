{
  "profileId": "default",
  "timeZone": "Asia/Kolkata",
  "interests": [
    "artificial intelligence research",
    "software architecture",
    "learning science"
  ],
  "learner": {
    "level": "technically experienced",
    "goal": "build durable understanding and turn useful ideas into experiments",
    "lessonMinutes": 15
  },
  "sources": [
    {
      "name": "Hacker News",
      "url": "https://hnrss.org/frontpage",
      "limit": 12
    },
    {
      "name": "arXiv Artificial Intelligence",
      "url": "https://export.arxiv.org/rss/cs.AI",
      "limit": 12
    }
  ],
  "provider": {
    "kind": "openai-compatible",
    "baseUrl": "https://api.deepseek.com",
    "apiKeyEnv": "DEEPSEEK_API_KEY",
    "model": "deepseek-v4-pro",
    "maxTokens": 8192,
    "timeoutSeconds": 600,
    "retries": 2
  },
  "content": {
    "aiExplorationEnabled": false,
    "maxArticleBytes": 524288,
    "maxArticleCharacters": 16000
  },
  "deliveries": [
    {
      "id": "morning-email",
      "kind": "resend",
      "enabled": false,
      "apiKeyEnv": "RESEND_API_KEY",
      "from": "Learnloom <daily@updates.example.com>",
      "to": "you@example.com",
      "subjectPrefix": "Learnloom"
    }
  ],
  "storage": {
    "dataDirectory": "data",
    "outputDirectory": "output"
  },
  "limits": {
    "maxItems": 18,
    "maxItemCharacters": 1800,
    "maxIntermediateCharacters": 24000,
    "historyEntries": 14
  }
}
