LEARNLOOM_ENV=development
LOG_LEVEL=info
HTTP_ADDR=:3000
WORKER_METRICS_ADDR=:9090
LEARNLOOM_ROOT_DOMAIN=learnloom.test
LEARNLOOM_APP_ORIGIN=https://app.learnloom.test
VITE_LEARNLOOM_ROOT_DOMAIN=learnloom.test
CSRF_SECRET=generate-at-least-32-random-characters

POSTGRES_PASSWORD=replace-me
DATABASE_URL=postgres://learnloom:replace-me@postgres:5432/learnloom?sslmode=disable

S3_BUCKET=learnloom-dossiers
S3_REGION=us-east-1
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY_ID=replace-me
S3_SECRET_ACCESS_KEY=replace-with-at-least-8-characters
S3_USE_PATH_STYLE=true

MODEL_BASE_URL=https://api.deepseek.com
MODEL_API_KEY=replace-me
MODEL_NAME=deepseek-chat
MODEL_TIMEOUT=10m
MODEL_RETRIES=2
MODEL_MAX_TOKENS=8192

VITE_CLERK_PUBLISHABLE_KEY=pk_test_replace_me
CLERK_PUBLISHABLE_KEY=pk_test_replace_me
CLERK_SECRET_KEY=sk_test_replace_me
CLERK_JWT_KEY=replace-with-clerk-pem-public-key
CLERK_WEBHOOK_SECRET=whsec_replace_me
CLERK_FRONTEND_ORIGIN=https://your-instance.clerk.accounts.dev

RESEND_API_KEY=re_replace_me
RESEND_FROM=Learnloom <dossiers@example.com>
RESEND_SUBJECT_PREFIX=Learnloom

# Enable with: docker compose --profile discovery up -d
SOURCE_DISCOVERY_ENABLED=false
SEARXNG_BASE_URL=http://searxng:8080
SEARXNG_SECRET=replace-with-a-long-random-secret
SEARXNG_TIMEOUT=8s
SOURCE_DISCOVERY_MAX_QUERIES=4
SOURCE_DISCOVERY_MAX_CANDIDATES=30
SOURCE_DISCOVERY_MAX_ACTIVE=8
SOURCE_MIN_USABLE_ITEMS=4
SOURCE_TARGET_USABLE_ITEMS=8
SOURCE_REFRESH_INTERVAL=12h
SOURCE_DEFAULT_MAX_STALE_AGE=720h
