# Required by the default OpenAI-compatible DeepSeek configuration.
DEEPSEEK_API_KEY=replace_with_your_deepseek_key

# Required for live email after enabling the Resend delivery in config.json.
RESEND_API_KEY=replace_with_your_resend_key

# Optional. Docker sets this to /data automatically.
# LEARNLOOM_HOME=/var/lib/learnloom
